<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">

  <Id>a2f43e88-8d0f-43ca-9d88-aa4982ea65ee</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Rosli Dahlan Saravana Partnership</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="RDS Email Signature"/>
  <Description DefaultValue="Inserts the RDS firm signature on all emails and replies"/>
  <IconUrl DefaultValue="https://rdslawpartners.github.io/rds-addin/icon-80.png"/>
  <HighResolutionIconUrl DefaultValue="https://rdslawpartners.github.io/rds-addin/icon-128.png"/>
  <SupportUrl DefaultValue="https://www.rdslawpartners.com"/>

  <AppDomains>
    <AppDomain>https://rdslawpartners.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rdslawpartners.github.io/rds-addin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" MinVersion="1.3"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile.Url"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="rdsSignatureGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="insertSigBtn">
                  <Label resid="Btn.Label"/>
                  <Supertip>
                    <Title resid="Btn.Label"/>
                    <Description resid="Btn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>insertSignature</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16"  DefaultValue="https://rdslawpartners.github.io/rds-addin/icon-16.png"/>
        <bt:Image id="Icon.32"  DefaultValue="https://rdslawpartners.github.io/rds-addin/icon-32.png"/>
        <bt:Image id="Icon.80"  DefaultValue="https://rdslawpartners.github.io/rds-addin/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://rdslawpartners.github.io/rds-addin/function.html"/>
        <bt:Url id="Taskpane.Url"     DefaultValue="https://rdslawpartners.github.io/rds-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="RDS Signature"/>
        <bt:String id="Btn.Label"  DefaultValue="Insert Signature"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Btn.Tooltip" DefaultValue="Insert the RDS firm email signature"/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
